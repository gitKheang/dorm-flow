{
  "name": "dormflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "DIST_DIR=.next-dev next dev -p 4028",
    "dev:turbo": "DIST_DIR=.next-dev next dev --turbopack -p 4028",
    "build": "next build",
    "start": "next start -p 4028",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md,json}\"",
    "serve": "next start -p 4028",
    "type-check": "tsc --noEmit",
    "validate:mock-data": "tsx scripts/validate-mock-data.ts",
    "validate:invitations": "tsx scripts/validate-invitation-lifecycle.ts",
    "validate:multi-dorm": "tsx scripts/validate-multi-dorm.ts",
    "validate:workflow-safety": "tsx scripts/validate-workflow-safety.ts"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "lucide-react": "^1.7.0",
    "next": "15.1.11",
    "react": "19.0.3",
    "react-dom": "19.0.3",
    "react-hook-form": "^7.72.0",
    "recharts": "^2.15.2",
    "sonner": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@netlify/plugin-nextjs": "^5.11.1",
    "@types/node": "^20",
    "@types/react": "19.0.3",
    "@types/react-dom": "19.0.3",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "autoprefixer": "10.4.2",
    "eslint": "^9",
    "eslint-config-next": "^15.2.4",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "postcss": "8.4.8",
    "prettier": "^3.5.3",
    "tailwindcss": "3.4.6",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
